{
  "buildCommand": "npm install && node scripts/sync-game-assets.mjs && cd admin && npm install && npm run build && cd ../games/game01 && npm install && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "/admin/$1" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/game01/(.*)", "destination": "/game01/$1" },
    { "source": "/game01", "destination": "/game01/index.html" }
  ],
  "redirects": [
    { "source": "/", "destination": "/game01", "statusCode": 302 }
  ]
}
